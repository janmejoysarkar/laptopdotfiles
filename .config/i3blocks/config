#[separator]

[cpu]
label=MHz
command= cat /proc/cpuinfo | grep MHz | cut -d ":" -f2 | sort -n | tail -n1
interval=3

[separator]

[memory]
command=$HOME/.config/i3blocks/memory/memory
label=
interval=30

[separator]

[disk]
label= 
command=df -h | grep "/$" | awk '{print $5}'
interval=600

[separator]

[volume]
label=𝅘𝅥𝅮  
command=pamixer --get-volume-human
interval=1
signal=1

[separator]

[conservation_mode]
command=$HOME/.config/i3blocks/custom/batteryCmode_check.sh
interval=30

[battery2]
command= acpi | grep -i "Battery 0" | cut -d ":" -f2 | cut -d "," -f 1,2
interval=30

[pstate]
label= 
command=$HOME/.config/i3blocks/custom/powerprofile_switch.sh
interval=30

[separator]
[date]
label= 
command=date '+%a, %d %b'
interval=10

[time]
label= 
command=echo "$(date '+%H:%M %Z') | $(TZ=Europe/Berlin date '+%H:%M %Z')"
interval=30

[separator]

[dropbox]
command=$HOME/.config/i3blocks/custom/dropbox_status.sh
interval=2

